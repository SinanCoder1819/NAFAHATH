<main class="min-h-screen bg-[#060606] text-white py-12 px-4 md:px-8 lg:px-12">
    <div class="max-w-7xl mx-auto flex flex-col lg:flex-row gap-8">
        
        <aside class="w-full lg:w-72 shrink-0">
            <div class="bg-[#0f0f0f] border border-gray-800 rounded-3xl p-8 sticky top-28 shadow-2xl">
                <div class="mb-10">
                    <p class="text-[10px] uppercase tracking-[0.3em] text-[#C5A267] font-bold mb-6 opacity-80">Dashboard</p>
                    <nav class="flex flex-col gap-2">
                        <a href="/profile" class="group flex items-center gap-4 px-4 py-3 rounded-xl bg-[#C5A267]/10 text-[#C5A267] border border-[#C5A267]/20 transition-all">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                            <span class="text-sm font-medium">Profile</span>
                        </a>
                        
                        <% const navLinks = [
                            { href: '/orders', label: 'My Orders', icon: 'M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z' },
                            { href: '/wallet', label: 'Wallet', icon: 'M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z' },
                            { href: '/address', label: 'Addresses', icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z' },
                            { href: '/referrals', label: 'Refer & Earn', icon: 'M12 8v13m0-13V6a2 2 0 112 2h-2zm0 0V5.5A2.5 2.5 0 109.5 8H12z' }
                        ] %>

                        <% navLinks.forEach(link => { %>
                            <a href="<%= link.href %>" class="group flex items-center gap-4 px-4 py-3 rounded-xl text-gray-400 hover:bg-white/5 hover:text-white transition-all border border-transparent">
                                <svg class="w-5 h-5 opacity-50 group-hover:opacity-100 transition-opacity" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="<%= link.icon %>"/></svg>
                                <span class="text-sm font-medium"><%= link.label %></span>
                            </a>
                        <% }) %>
                    </nav>
                </div>

                <div class="pt-6 border-t border-gray-800">
                    <a href="/auth/logout" class="flex items-center gap-4 px-4 py-3 text-red-400 hover:bg-red-500/10 rounded-xl transition-all group">
                        <svg class="w-5 h-5 group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
                        <span class="text-sm font-medium">Logout</span>
                    </a>
                </div>
            </div>
        </aside>

        <section class="flex-1 space-y-8">
            
            <div class="relative overflow-hidden bg-[#0f0f0f] border border-gray-800 rounded-3xl p-10 shadow-2xl">
                <div class="absolute -top-24 -right-24 w-64 h-64 bg-[#C5A267]/10 blur-[80px] rounded-full"></div>
                
                <div class="relative z-10 flex flex-col md:flex-row items-center gap-10">
                    <div class="relative">
                        <div class="w-28 h-28 rounded-full border-2 border-[#C5A267]/30 p-1">
                            <div class="w-full h-full rounded-full bg-gradient-to-br from-gray-800 to-black flex items-center justify-center overflow-hidden">
                                <svg class="w-14 h-14 text-gray-600" fill="currentColor" viewBox="0 0 24 24"><path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/></svg>
                            </div>
                        </div>
                        <div class="absolute bottom-1 right-1 w-6 h-6 bg-[#00FFFF] rounded-full border-4 border-[#0f0f0f] shadow-lg"></div>
                    </div>

                    <div class="text-center md:text-left flex-1">
                        <h2 class="text-3xl md:text-4xl font-serif text-white mb-2 italic">Greetings, Sinan</h2>
                        <p class="text-gray-400 text-sm tracking-wide max-w-md">Your personal essence, curated. Manage your profile details and security below.</p>
                    </div>

                    <a href="user/editProfile" class="shrink-0">
                        <button class="bg-white text-black px-8 py-3 rounded-full text-[11px] font-bold uppercase tracking-widest hover:bg-[#00FFFF] hover:shadow-[0_0_20px_rgba(0,255,255,0.4)] transition-all transform active:scale-95">
                            Edit Profile
                        </button>
                    </a>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mt-12 pt-10 border-t border-gray-800/50">
                    <div class="space-y-1">
                        <span class="text-[9px] uppercase tracking-[0.2em] text-gray-500 font-bold">Email Address</span>
                        <p class="text-sm font-medium text-gray-200">sinan@gmail.com</p>
                    </div>
                    <div class="space-y-1">
                        <span class="text-[9px] uppercase tracking-[0.2em] text-gray-500 font-bold">Phone Number</span>
                        <p class="text-sm font-medium text-gray-200">+91 9061181938</p>
                    </div>
                </div>
            </div>

            <div class="bg-[#0f0f0f] border border-gray-800 rounded-3xl p-10 shadow-2xl">
                <div class="flex items-center gap-4 mb-10">
                    <div class="w-10 h-10 rounded-lg bg-[#00FFFF]/10 flex items-center justify-center border border-[#00FFFF]/20">
                        <svg class="w-5 h-5 text-[#00FFFF]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
                    </div>
                    <div>
                        <h3 class="text-xl font-medium">Security & Access</h3>
                        <p class="text-xs text-gray-500 tracking-wide">Last password change: 2 months ago</p>
                    </div>
                </div>

                <div id="responseMessage" class="hidden mb-6 p-4 rounded-xl text-xs font-medium border"></div>

                <div class="flex flex-col sm:flex-row gap-4">
                    <button onclick="handleSecurityAction('changePassword')" 
                            class="flex-1 bg-transparent border border-gray-700 text-white px-6 py-4 rounded-2xl text-[10px] font-bold uppercase tracking-widest hover:border-[#00FFFF] hover:text-[#00FFFF] transition-all">
                        Change Password
                    </button>
                    <button onclick="handleSecurityAction('changeEmail')" 
                            class="flex-1 bg-transparent border border-gray-700 text-white px-6 py-4 rounded-2xl text-[10px] font-bold uppercase tracking-widest hover:border-[#00FFFF] hover:text-[#00FFFF] transition-all">
                        Update Email
                    </button>
                </div>
            </div>

        </section>
    </div>
</main>

<script>
    // AJAX functionality for security updates
    async function handleSecurityAction(action) {
        const msgDiv = document.getElementById('responseMessage');
        
        // Example structure for triggering modals or requests
        const confirmAction = confirm(`Are you sure you want to ${action.replace(/([A-Z])/g, ' $1').toLowerCase()}?`);
        
        if (confirmAction) {
            try {
                // You can point this to your specific routes: /user/change-password or /user/change-email
                const response = await fetch(`/user/${action}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' }
                });

                const result = await response.json();

                if (response.ok) {
                    showStatus(result.message || "Request successful", "success");
                } else {
                    showStatus(result.error || "Something went wrong", "error");
                }
            } catch (err) {
                showStatus("Network error occurred", "error");
            }
        }
    }

    function showStatus(text, type) {
        const msgDiv = document.getElementById('responseMessage');
        msgDiv.innerText = text;
        msgDiv.classList.remove('hidden', 'bg-red-900/50', 'text-red-200', 'bg-green-900/50', 'text-green-200', 'border-red-800', 'border-green-800');
        msgDiv.classList.add('block', 'border');

        if (type === "error") {
            msgDiv.classList.add('bg-red-900/50', 'text-red-200', 'border-red-800');
        } else {
            msgDiv.classList.add('bg-green-900/50', 'text-green-200', 'border-green-800');
        }
    }

    // Logic for the 'Edit Profile' button
    document.getElementById('editProfileBtn').addEventListener('click', () => {
        // Logic to toggle input fields or redirect to edit page
        console.log('Edit profile clicked');
    });
</script>