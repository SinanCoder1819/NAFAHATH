<section class="flex items-center justify-center px-6 py-12 md:py-20">
    <div class="w-full max-w-[440px] border border-gray-800 rounded-[40px] p-8 md:p-10 flex flex-col items-center bg-black">
        
        <div class="text-center">
            <h2 class="text-2xl font-semibold mb-2 text-white">Welcome Back</h2>
            <p class="text-gray-400 text-sm mb-8">Log in to continue to your account</p>
        </div>

        <button type="button" class="w-full bg-white text-black py-3 rounded-lg flex items-center justify-center gap-3 font-medium hover:bg-gray-200 transition-colors mb-6">
            <img src="https://www.gstatic.com/firebasejs/ui/2.0.0/images/auth/google.svg" class="w-5 h-5" alt="Google">
            <span class="text-sm">Sign in with Google</span>
        </button>

        <div class="w-full flex items-center gap-4 mb-8">
            <div class="h-[1px] bg-gray-700 flex-grow"></div>
            <span class="text-gray-500 text-xs lowercase">or</span>
            <div class="h-[1px] bg-gray-700 flex-grow"></div>
        </div>

        <div id="responseMessage" class="hidden w-full mb-4 p-3 rounded-lg text-xs font-medium text-center"></div>

        <form id="loginForm" class="w-full space-y-6">
            <div>
                <label class="block text-xs font-medium text-gray-300 mb-2 ml-1">Email</label>
                <input type="email" name="email" id="email"  placeholder="Enter your email" 
                    class="w-full bg-transparent border border-gray-700 rounded-xl px-4 py-3.5 outline-none focus:border-[#00FFFF] transition-all text-sm text-white">
            </div>

            <div class="relative">
                <div class="flex justify-between items-center mb-2">
                    <label class="text-xs font-medium text-gray-300 ml-1">Password</label>
                </div>
                <div class="relative">
                    <input type="password" name="password" id="password"  placeholder="Enter your password" 
                        class="w-full bg-transparent border border-gray-700 rounded-xl px-4 py-3.5 outline-none focus:border-[#00FFFF] transition-all text-sm text-white">
                    
                    <button type="button" onclick="togglePassword('password')" class="absolute right-4 top-1/2 -translate-y-1/2 text-gray-500 hover:text-white transition">
                        <svg id="eyeIcon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" />
                            <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                        </svg>
                    </button>
                </div>
            </div>

            <div class="pt-2 space-y-4">
                <button type="submit" id="submitBtn" class="w-full bg-[#00FFFF] text-black font-bold py-3.5 rounded-xl hover:opacity-90 shadow-[0_0_20px_rgba(0,255,255,0.2)] transition-all text-sm uppercase tracking-widest">
                    Log In
                </button>
                
                <a href="/auth/signup" class="block w-full text-center border border-gray-700 text-white font-medium py-3.5 rounded-xl hover:bg-white/5 transition-colors text-sm">
                    Signup
                </a>
            </div>
        </form>

        <div class="text-center mt-6">
            <a href="/auth/forgot-password" class="text-xs text-blue-500 hover:underline font-medium">Forget Password?</a>
        </div>
    </div>
</section>

<div id="loadingModal" class="fixed inset-0 z-50 hidden flex flex-col items-center justify-center bg-black/80 backdrop-blur-sm">
    <div class="flex flex-col items-center bg-gray-900 border border-gray-800 p-10 rounded-[32px] shadow-2xl">
        <div class="w-12 h-12 border-4 border-[#00FFFF]/20 border-t-[#00FFFF] rounded-full animate-spin mb-4"></div>
        <h3 class="text-white font-semibold text-lg">Authenticating</h3>
        <p class="text-gray-400 text-xs mt-2">Checking your credentials...</p>
    </div>
</div>

<script>
    // 1. Toggle Password Visibility
    function togglePassword(id) {
        const passwordInput = document.getElementById(id);
        const eyeIcon = document.getElementById('eyeIcon');
        
        if (passwordInput.type === 'password') {
            passwordInput.type = 'text';
            eyeIcon.innerHTML = `<path stroke-linecap="round" stroke-linejoin="round" d="M3.98 8.223A10.477 10.477 0 001.934 12C3.226 16.338 7.244 19.5 12 19.5c.993 0 1.953-.138 2.863-.395M6.228 6.228A10.45 10.45 0 0112 4.5c4.756 0 8.773 3.162 10.065 7.498a10.523 10.523 0 01-4.293 5.774M6.228 6.228L3 3m3.228 3.228l3.65 3.65m7.894 7.894L21 21m-3.228-3.228l-3.65-3.65m0 0a3 3 0 10-4.243-4.243m4.242 4.242L9.88 9.88" />`;
        } else {
            passwordInput.type = 'password';
            eyeIcon.innerHTML = `<path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />`;
        }
    }

    // 2. Handle Login Submission
    const loginForm = document.getElementById('loginForm');
    const submitBtn = document.getElementById('submitBtn');
    const msgDiv = document.getElementById('responseMessage');
    const loadingModal = document.getElementById('loadingModal');

    loginForm.addEventListener('submit', async function(e) {
        e.preventDefault();

        // 1. Show the loading modal immediately
        loadingModal.classList.remove('hidden');
        submitBtn.disabled = true;
        msgDiv.classList.add('hidden');

        try {
            // 2. Attempt the real connection
            const response = await fetch('/auth/login', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(Object.fromEntries(new FormData(this)))
            });

            const result = await response.json();

            if (response.ok) {
                showMessage("Login successful!", "success");
                setTimeout(() => {
                    window.location.href = result.redirectUrl || "/auth/home";
                }, 1000);
            } else {
                loadingModal.classList.add('hidden');
                showMessage(result.message || "Invalid credentials", "error");
                submitBtn.disabled = false;
            }
        } catch (error) {
            // 3. BYPASS ERROR: If server is down, redirect anyway after a short delay
            console.warn("Server not found, redirecting to home anyway...");
            
            setTimeout(() => {
                window.location.href = "/"; 
            }, 1500);
        }
    });

    // 3. Helper Function for Messages
    function showMessage(text, type) {
        msgDiv.innerText = text;
        msgDiv.classList.remove('hidden', 'bg-red-900/50', 'text-red-200', 'bg-green-900/50', 'text-green-200', 'border-red-800', 'border-green-800');
        msgDiv.classList.add('block', 'border');

        if (type === "error") {
            msgDiv.classList.add('bg-red-900/50', 'text-red-200', 'border-red-800');
        } else {
            msgDiv.classList.add('bg-green-900/50', 'text-green-200', 'border-green-800');
        }
    }
</script>