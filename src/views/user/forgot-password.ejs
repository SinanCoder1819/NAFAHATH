<main class="min-h-screen bg-[#0a0a0a] flex items-center justify-center p-6 relative overflow-hidden">
    <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-cyan-500/10 blur-[120px] rounded-full"></div>
    <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-cyan-500/5 blur-[120px] rounded-full"></div>

    <div class="w-full max-w-md bg-[#0f0f0f]/80 backdrop-blur-xl border border-gray-800 rounded-[2.5rem] p-10 md:p-12 relative z-10 shadow-2xl">
        

        <div class="text-center mb-8">
            <h2 class="text-2xl font-semibold text-white mb-3">Forgot Your Password?</h2>
            <p class="text-gray-400 text-sm leading-relaxed">No problem. Enter your email address below and we'll send you an OTP to your email.</p>
        </div>

        <form id="forgotPasswordForm" class="space-y-6">
            <div>
                <label class="block text-[10px] font-medium text-gray-500 mb-2 ml-1 uppercase tracking-widest">Email Address</label>
                <input type="email" name="email"  placeholder="Enter your email" 
                    class="w-full bg-black/40 border border-gray-700 rounded-2xl px-5 py-4 outline-none focus:border-cyan-400 focus:ring-1 focus:ring-cyan-400/30 transition-all text-sm text-white placeholder:text-gray-600">
            </div>

            <button type="submit" class="w-full bg-cyan-400 text-black py-4 rounded-2xl font-bold uppercase tracking-widest text-xs hover:bg-cyan-300 hover:scale-[1.01] active:scale-95 transition-all shadow-[0_0_25px_rgba(0,255,255,0.2)]">
                Send OTP
            </button>
        </form>

        <div class="mt-8 text-center">
            <a href="/auth/login" class="text-gray-500 text-xs hover:text-white transition-colors border-b border-transparent hover:border-gray-500 pb-0.5">Return to Login</a>
        </div>
    </div>
</main>